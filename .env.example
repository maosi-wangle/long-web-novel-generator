# =========================
# API / Workbench
# =========================
API_HOST=127.0.0.1
API_PORT=9005

# jsonl: 本地文件存储
# neo4j: 审计事件尝试写入 Neo4j，章节快照仍走本地 fallback
GRAPH_STORE_BACKEND=jsonl

# 可选：自定义本地运行期文件位置
# REVIEW_AUDIT_PATH=backend/runtime/review_audit.jsonl
# CHAPTER_STATE_PATH=backend/runtime/chapter_state.json
# NOVEL_STATE_PATH=backend/runtime/novel_state.json

# =========================
# LLM
# =========================
# 1 表示使用本地 mock 文本；0 表示走真实模型 API
USE_MOCK_LLM=1

# 填写你的大模型 API 密钥
LLM_API_KEY=your_api_key_here

# 填写大模型的调用地址（带 /v1）
LLM_BASE_URL=https://api.your-provider.com/v1

# 可选：模型名、采样温度、超时和重试
LLM_MODEL_NAME=qwen3-max-preview
LLM_TEMPERATURE=0.9
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2

# =========================
# Debug / Dev
# =========================
SHOW_DRAFT_SYSTEM_PROMPT=0
SHOW_DRAFT_PROMPT=0
MAX_REWRITES=3
AUTO_APPROVE_REVIEW=0
CRITIC_FORCE_FAIL=0
